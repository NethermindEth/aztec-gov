# Governance contract addresses (required)
# Option A: Fetch from Aztec node:  yarn get-l1-addresses
# Option B: Deploy your own:        PRIVATE_KEY=0x... ./scripts/deploy-test-governance.sh
NEXT_PUBLIC_GOVERNANCE_ADDRESS=
NEXT_PUBLIC_STAKING_ASSET_ADDRESS=
NEXT_PUBLIC_GSE_ADDRESS=

# Aztec node URL (used by get-l1-addresses script, defaults to testnet)
# AZTEC_NODE_URL=https://rpc.testnet.aztec-labs.com

# RPC URL (defaults to Sepolia public node)
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Chain ID (defaults to 11155111 / Sepolia)
NEXT_PUBLIC_CHAIN_ID=11155111

# WalletConnect project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Microsoft Clarity analytics tag (leave empty to disable)
NEXT_PUBLIC_CLARITY_TAG=

# Staking indexer base URL for ATP/Staker discovery (used to attribute voting
# power held by a user's Staker contract to their wallet).
# Leave empty to use chain-default (mainnet: dgk9duhuxabbq.cloudfront.net,
# sepolia: d1lzkj24db7400.cloudfront.net). Override if traffic rotates to
# the blue deployment or during staging.
NEXT_PUBLIC_STAKING_INDEXER_URL=

# ATP Factory address (only needed for `yarn seed-staker-voting --create-atp`).
# Runner's PRIVATE_KEY must be the factory owner, else createLATP reverts with
# OwnableUnauthorizedAccount.
ATP_FACTORY_ADDRESS=

# Dev-only: comma-separated list of staker addresses to treat as if the indexer
# returned them for the connected wallet. Used by `yarn bootstrap-anvil` local
# flow where there is no staking indexer. Leave empty in production.
NEXT_PUBLIC_DEV_EXTRA_STAKERS=
